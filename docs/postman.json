    {
      "name": "Student",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"TestPass123\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/student/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "student", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"TestPass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/student/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "student", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);"
                ]
              }
            }
          ]
        },
