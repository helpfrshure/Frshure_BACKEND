{
  "info": {
    "name": "FRSHURE API",
    "description": "FRSHURE Student Jobs Marketplace API\n\nBase URL: {{base_url}}/api/v1\n\nAuthentication: Bearer token\n\nAfter signup/login, set `accessToken` variable from response.",
